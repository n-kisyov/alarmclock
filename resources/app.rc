#include <windows.h>
#include "../src/resource.h"

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"

IDI_APPICON      ICON   "alarmclock.ico"
IDR_DIGITALFONT RCDATA "digital-7.ttf"

IDD_SETTINGS DIALOGEX 0, 0, 260, 265
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX   "Dark Mode", IDC_DARKMODE, 15, 12, 100, 14

    GROUPBOX       "Clock Style", -1, 15, 35, 220, 38
    AUTORADIOBUTTON "Digital", IDC_CLOCK_DIGITAL, 25, 50, 50, 14, WS_GROUP
    AUTORADIOBUTTON "Analog",  IDC_CLOCK_ANALOG,  85, 50, 50, 14

    AUTOCHECKBOX   "24-Hour Clock", IDC_HOUR24, 15, 85, 100, 14

    AUTOCHECKBOX   "Enable Alarms", IDC_ALARMS_ENABLED, 15, 106, 100, 14

    LTEXT          "Alarm slots:", -1, 15, 128, 55, 12
    COMBOBOX       IDC_ALARM_COUNT, 80, 126, 48, 100, CBS_DROPDOWNLIST | CBS_OWNERDRAWFIXED | CBS_HASSTRINGS | WS_VSCROLL

    LTEXT          "Snooze (min):", -1, 15, 150, 55, 12
    COMBOBOX       IDC_SNOOZE_MINUTES, 80, 148, 48, 100, CBS_DROPDOWNLIST | CBS_OWNERDRAWFIXED | CBS_HASSTRINGS | WS_VSCROLL

    GROUPBOX       "Alarm Sound", -1, 15, 172, 220, 38
    AUTORADIOBUTTON "Simple Tone", IDC_SOUND_SIMPLE, 25, 187, 70, 14, WS_GROUP
    AUTORADIOBUTTON "MP3 (from songs\\)", IDC_SOUND_MP3, 105, 187, 120, 14

    PUSHBUTTON     "OK", IDOK, 100, 235, 70, 18
    PUSHBUTTON     "Cancel", IDCANCEL, 180, 235, 70, 18
END

IDD_ALARM DIALOGEX 0, 0, 240, 155
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Edit Alarm"
FONT 9, "Segoe UI"
BEGIN
    LTEXT          "Label:", -1, 15, 14, 30, 12
    EDITTEXT       IDC_ALARM_LABEL, 55, 12, 170, 14, ES_AUTOHSCROLL

    LTEXT          "Hour (0-23):", -1, 15, 34, 55, 12
    EDITTEXT       IDC_ALARM_HOUR, 75, 32, 40, 14, ES_NUMBER | ES_AUTOHSCROLL
    LTEXT          "Min (0-59):", -1, 125, 34, 50, 12
    EDITTEXT       IDC_ALARM_MINUTE, 175, 32, 40, 14, ES_NUMBER | ES_AUTOHSCROLL

    LTEXT          "Repeat:", -1, 15, 54, 35, 12
    COMBOBOX       IDC_ALARM_REPEAT, 55, 52, 100, 80, CBS_DROPDOWNLIST | CBS_OWNERDRAWFIXED | CBS_HASSTRINGS | WS_VSCROLL

    AUTOCHECKBOX   "Alarm enabled", IDC_ALARM_ENABLED, 15, 78, 80, 14

    PUSHBUTTON     "OK", IDOK, 65, 115, 70, 18
    PUSHBUTTON     "Cancel", IDCANCEL, 145, 115, 70, 18
END
