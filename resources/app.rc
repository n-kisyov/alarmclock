#include <windows.h>
#include "../src/resource.h"

CREATEPROCESS_MANIFEST_RESOURCE_ID RT_MANIFEST "app.manifest"

IDI_APPICON      ICON   "alarmclock.ico"
IDR_DIGITALFONT RCDATA "digital-7.ttf"

IDD_SETTINGS DIALOGEX 0, 0, 260, 220
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Settings"
FONT 9, "Segoe UI"
BEGIN
    AUTOCHECKBOX   "Dark Mode", IDC_DARKMODE, 15, 12, 100, 14

    GROUPBOX       "Clock Style", -1, 15, 35, 220, 38
    AUTORADIOBUTTON "Digital", IDC_CLOCK_DIGITAL, 25, 50, 50, 14, WS_GROUP
    AUTORADIOBUTTON "Analog",  IDC_CLOCK_ANALOG,  85, 50, 50, 14

    AUTOCHECKBOX   "Enable Alarms", IDC_ALARMS_ENABLED, 15, 85, 100, 14

    LTEXT          "Alarm slots:", -1, 15, 106, 55, 12
    COMBOBOX       IDC_ALARM_COUNT, 80, 104, 48, 100, CBS_DROPDOWNLIST | CBS_OWNERDRAWFIXED | CBS_HASSTRINGS | WS_VSCROLL

    GROUPBOX       "Alarm Sound", -1, 15, 128, 220, 38
    AUTORADIOBUTTON "Simple Tone", IDC_SOUND_SIMPLE, 25, 143, 70, 14, WS_GROUP
    AUTORADIOBUTTON "MP3 (from songs\\)", IDC_SOUND_MP3, 105, 143, 120, 14

    PUSHBUTTON     "OK", IDOK, 100, 190, 70, 18
    PUSHBUTTON     "Cancel", IDCANCEL, 180, 190, 70, 18
END

IDD_ALARM DIALOGEX 0, 0, 200, 115
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Edit Alarm"
FONT 9, "Segoe UI"
BEGIN
    LTEXT          "Hour (0-23):", -1, 15, 15, 55, 12
    EDITTEXT       IDC_ALARM_HOUR, 85, 13, 40, 14, ES_NUMBER | ES_AUTOHSCROLL
    LTEXT          "Minute (0-59):", -1, 15, 35, 55, 12
    EDITTEXT       IDC_ALARM_MINUTE, 85, 33, 40, 14, ES_NUMBER | ES_AUTOHSCROLL
    AUTOCHECKBOX   "Alarm enabled", IDC_ALARM_ENABLED, 15, 58, 80, 14

    PUSHBUTTON     "OK", IDOK, 50, 88, 70, 18
    PUSHBUTTON     "Cancel", IDCANCEL, 130, 88, 70, 18
END
